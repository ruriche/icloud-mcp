# iCloud MCP Configuration
#
# ============================================================
# MODE SELECTION
# ============================================================
#
# LOCAL MODE (default): Uses AppleScript to access macOS apps
# - Faster (no network latency)
# - Works offline
# - Access to Reminders, Notes, Messages, Safari
# - Requires macOS
#
# CLOUD MODE: Uses iCloud protocols (IMAP, CalDAV, CardDAV)
# - Works from any computer
# - Requires iCloud credentials
# - Only Email, Calendar, Contacts

USE_LOCAL_MODE=true    # Set to 'false' for cloud mode

# ============================================================
# CLOUD MODE CREDENTIALS (only needed if USE_LOCAL_MODE=false)
# ============================================================
#
# To get your app-specific password:
# 1. Go to https://appleid.apple.com
# 2. Sign in with your Apple ID
# 3. Security → App-Specific Passwords → Generate
# 4. Name it "iCloud MCP"
# 5. Copy the 16-character password below

ICLOUD_EMAIL=your-email@icloud.com
ICLOUD_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ============================================================
# OPTIONAL
# ============================================================

# Enable test mode (uses mock data)
# USE_TEST_MODE=true
